# your phone number so we dont ACTUALLY call anyone
DEMO_PHONE=+1XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
# they used GROQ last year so if gemini doenst work im going to try this
GROQ_API_KEY=your_groq_key_here


# ─────────────────────────────────────────────────────────────────────────────
# Contractor search (fall back to Gemini if not set) (that is if we get free gemini api credits)
# Perplexity Sonar — https://perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_key_here


# ─────────────────────────────────────────────────────────────────────────────
# Voice calling (enable with a CALLS ON toggle in the app so we dont accidentally call fr)

# ElevenLabs — https://elevenlabs.io
# 1. Create a Conversational AI agent in your ElevenLabs dashboard
# 2. Paste the system prompt from src/lib/voice.ts into the agent
# 3. Connect your Twilio number in the Phone Numbers tab
# 4. Copy Agent ID and Phone Number ID below
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_AGENT_ID=your_agent_id_here
ELEVENLABS_PHONE_NUMBER_ID=your_phone_number_id_here

# Twilio — https://twilio.com (free trial: ~$15 credit + 1 phone number)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# ─────────────────────────────────────────────────────────────────────────────
# Google Sheets as a database (for logs + contractor history)
# maybe we can use OMI somehow instead?

# Setup:
# 1. Create a Google Sheet with these 6 tabs:
#    Submissions | Diagnoses | Contractors | Negotiations | Conversations | ContractorProfiles
# 2. Go to console.cloud.google.com → Enable Google Sheets API
# 3. Create a Service Account → download JSON key file
# 4. Share your Google Sheet with the service account email (Editor access)
# 5. Paste values below from the JSON key file

GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=bidbot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

